# Copy this file to .env (gitignored) and fill in real values before running
# `docker compose up -d --build`.

# Public domain this stack is served under (matches config_deploy_site.json).
DOMAIN=exogame.reinanbr.com

# Host port the proxy service binds to — must match config_deploy_site.json's
# upstream_port, since the host-level nginx/certbot forwards here.
PROXY_PORT=6969

# Phoenix's cookie/session signing secret. Generate with:
#   cd backend_elixir && mix phx.gen.secret
SECRET_KEY_BASE=
