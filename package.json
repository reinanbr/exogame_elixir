{
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend_elixir && mix phx.server",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "cd backend_elixir && mix deps.get && cd ../frontend && npm install",
    "start": "./start.sh",
    "test:integration": "node test_integration.mjs"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "phoenix": "^1.8.4"
  }
}
